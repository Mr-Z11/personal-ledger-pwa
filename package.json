{
  "name": "personal-ledger-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace @ledger/web run dev",
    "dev:api": "npm --workspace @ledger/api run dev",
    "build": "npm-run-all build:shared build:api build:web",
    "build:shared": "npm --workspace @ledger/shared run build",
    "build:api": "npm --workspace @ledger/api run build",
    "build:web": "npm --workspace @ledger/web run build",
    "test": "npm-run-all test:shared test:api test:web",
    "test:shared": "npm --workspace @ledger/shared run test",
    "test:api": "npm --workspace @ledger/api run test",
    "test:web": "npm --workspace @ledger/web run test",
    "typecheck": "npm-run-all typecheck:shared build:shared prisma:generate:api typecheck:api typecheck:web",
    "typecheck:shared": "npm --workspace @ledger/shared run typecheck",
    "typecheck:api": "npm --workspace @ledger/api run typecheck",
    "typecheck:web": "npm --workspace @ledger/web run typecheck",
    "prisma:generate:api": "npm --workspace @ledger/api run prisma:generate"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
